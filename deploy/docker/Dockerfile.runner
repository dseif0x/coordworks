# Runner image: stateless execution node, scale horizontally anywhere.
FROM --platform=$BUILDPLATFORM golang:1.25-alpine AS build
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/ cmd/
COPY internal/ internal/
ARG TARGETOS TARGETARCH
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH go build -o /coordworks-runner ./cmd/runner

FROM alpine:3.21
# CA bundle comes from the build stage (LLM APIs are HTTPS); adduser is a
# busybox builtin, so no packages need to be installed here.
RUN adduser -D coordworks
COPY --from=build /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
USER coordworks
COPY --from=build /coordworks-runner /usr/local/bin/coordworks-runner
ENV COORDWORKS_RUNNER_LABELS=runtime=docker
ENTRYPOINT ["coordworks-runner"]
